# MAGIC Agent Skills — Environment Variables
# Copy this file: cp .env.example .env
# Full reference (purpose, required vs optional, defaults): see ENV_VARS.md

# CLI installer: repo override (owner/name) to install from a fork/mirror.
# Default: Votee-AI/magic-agent-skills
MAGIC_REPO=

# Synthesis engine gate: set to 1 to HARD-FAIL if the engine is absent (CI uses 1).
# Leave unset locally to allow a graceful skip when the optional engine isn't installed.
MAGIC_REQUIRE_ENGINE=

# HuggingFace Hub (for private datasets)
HF_TOKEN=

# Database connectivity
DATABASE_URL=

# LLM for data synthesis
MAGIC_LLM_MODEL=
MAGIC_LLM_BASE_URL=
MAGIC_LLM_API_KEY=
MAGIC_LLM_MAX_TOKENS=
MAGIC_LLM_PROVIDER=
MAGIC_LLM_SEED=

# DataDesigner async engine: set to 0 to force the sync engine (deterministic ordering)
DATA_DESIGNER_ASYNC_ENGINE=

# Provider API keys (set the one(s) your model endpoint needs)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
NVIDIA_API_KEY=

# Matplotlib backend (recommended for headless/CI)
MPLBACKEND=Agg
